{% comment %}
  section-print-methods.liquid
{% endcomment %}
<style>
  .jp-methods {
    --ink: var(--color-foreground);
    --mid: rgba(var(--color-foreground-rgb), 0.55);
    --bg: var(--color-background);
    --rule: var(--color-border);
    --riso: #E8402A;
    --giclee: #1A4A8A;
    background: var(--bg);
    color: var(--ink);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    position: relative;
  }

  .jp-methods__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--padding-4xl);
  }

  /* ── Intro header ── */
  .jp-methods__intro {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--gap-3xl);
    align-items: end;
    border-top: 3px solid var(--riso);
    border-bottom: var(--style-border-width, 1px) solid var(--ink);
    padding-top: var(--padding-3xl);
    padding-bottom: var(--padding-4xl);
    margin-bottom: var(--padding-6xl);
  }

  .jp-methods__eyebrow {
    display: inline-block;
    font-family: var(--font-body--family);
    font-size: var(--font-size--2xs, 0.625rem);
    font-weight: 700;
    letter-spacing: var(--letter-spacing-md, 0.13em);
    text-transform: uppercase;
    line-height: 1;
    padding: 0.25em 0.6em;
    background-color: var(--ink);
    color: var(--bg);
    margin-bottom: 1rem;
  }

  .jp-methods__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(var(--font-size--3xl), 5vw, var(--font-size--6xl));
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: var(--letter-spacing--display-tight);
    margin: 0;
  }

  .jp-methods__heading em {
    font-style: italic;
    font-weight: 400;
  }

  .jp-methods__intro-body {
    font-size: 0.725rem;
    line-height: 1.25;
    color: var(--mid);
    margin: 0;
  }

  /* ── Method toggle tabs ── */
  .jp-methods__tabs {
    display: flex;
    gap: 0;
    margin-bottom: 0;
    border-bottom: var(--style-border-width, 1px) solid var(--ink);
  }

  .jp-methods__tab {
    font-family: var(--font-accent--family);
    font-size: var(--font-size--2xs);
    letter-spacing: var(--letter-spacing-md);
    text-transform: uppercase;
    background: transparent;
    border: var(--style-border-width, 1px) solid var(--rule);
    border-top: 3px solid transparent;
    padding: var(--padding-lg) var(--padding-4xl) 0.9rem;
    cursor: pointer;
    color: var(--mid);
    transition: color var(--hover-transition-duration) var(--hover-transition-timing), border-color var(--hover-transition-duration) var(--hover-transition-timing);
    position: relative;
    top: 1px;
  }

  .jp-methods__tab[aria-selected="true"] {
    color: var(--ink);
    border-top-color: var(--color-foreground);
    background: var(--bg);
  }

  .jp-methods__tab[data-method="riso"][aria-selected="true"] {
    border-top-color: var(--riso);
  }

  .jp-methods__tab[data-method="giclee"][aria-selected="true"] {
    border-top-color: var(--giclee);
  }

  /* ── Panels ── */
  .jp-methods__panel {
    display: none;
    padding-top: var(--padding-5xl);
  }

  .jp-methods__panel[aria-hidden="false"] {
    display: block;
  }

  /* ── Accordion guide entries ── */
  .jp-guide {
    border-bottom: var(--style-border-width, 1px) solid var(--rule);
  }

  .jp-guide__trigger {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    display: grid;
    grid-template-columns: 3rem 1fr 2rem;
    align-items: center;
    gap: var(--gap-xl);
    padding: var(--padding-2xl) 0;
    text-align: left;
    font-family: var(--font-accent--family);
    color: var(--ink);
  }

  .jp-guide__trigger:hover .jp-guide__title {
    color: var(--mid);
  }

  .jp-guide__num {
    font-size: 0.58rem;
    color: var(--mid);
    letter-spacing: 0.1em;
    font-style: italic;
  }

  .jp-guide__title {
    font-family: var(--font-heading--family);
    font-size: clamp(var(--font-size--lg), 2.5vw, var(--font-size--2xl));
    font-weight: 700;
    letter-spacing: var(--letter-spacing--heading-tight);
    line-height: 1;
    transition: color var(--hover-transition-duration) var(--hover-transition-timing);
  }

  .jp-guide__arrow {
    font-size: var(--font-size--xl);
    transition: transform var(--animation-speed-slow) var(--animation-easing);
    color: var(--mid);
    line-height: 1;
  }

  .jp-guide[open] .jp-guide__arrow {
    transform: rotate(45deg);
  }

  .jp-guide__body {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--gap-3xl);
    padding: 0 0 2.5rem 4.5rem;
    align-items: start;
  }

  .jp-guide__text {
    font-size: 0.725rem;
    line-height: 1.5;
    color: var(--mid);
  }

  .jp-guide__text strong {
    color: var(--ink);
    font-weight: 500;
  }

  .jp-guide__specs {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .jp-guide__spec-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.6rem 0;
    border-bottom: var(--style-border-width, 1px) solid var(--rule);
    font-size: var(--font-size--2xs);
    gap: var(--gap-lg);
  }

  .jp-guide__spec-row:last-child {
    border-bottom: none;
  }

  .jp-guide__spec-label {
    color: var(--mid);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-size: 0.55rem;
    flex-shrink: 0;
  }

  .jp-guide__spec-value {
    color: var(--ink);
    text-align: right;
    font-style: italic;
  }

  .jp-guide__image {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
    margin-top: 1.5rem;
    filter: saturate(0.85);
  }

  /* ── Method badge ── */
  .jp-badge {
    display: inline-block;
    font-size: var(--font-size--2xs);
    letter-spacing: var(--letter-spacing-md);
    text-transform: uppercase;
    padding: var(--padding-2xs) var(--padding-xs);
    border: var(--style-border-width, 1px) solid currentColor;
    border-radius: var(--style-border-radius-xs);
    margin-bottom: var(--padding-2xl);
  }

  .jp-badge--riso { color: var(--riso); }
  .jp-badge--giclee { color: var(--giclee); }

  /* ── CTA strip ── */
  .jp-methods__cta {
    margin-top: var(--padding-6xl);
    padding: 2.5rem var(--padding-5xl);
    border: var(--style-border-width, 1px) solid var(--ink);
    border-left: 3px solid var(--riso);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--gap-2xl);
  }

  .jp-methods__cta-text {
    font-family: var(--font-heading--family);
    font-size: clamp(var(--font-size--md), 2vw, var(--font-size--lg));
    font-style: italic;
    margin: 0;
    font-weight: 400;
  }

  .jp-methods__cta-link {
    font-family: var(--font-accent--family);
    font-size: var(--font-size--2xs);
    letter-spacing: var(--letter-spacing-md);
    text-transform: uppercase;
    color: var(--bg);
    background: var(--ink);
    text-decoration: none;
    padding: 0.9rem 1.8rem;
    border-radius: var(--style-border-radius-buttons-primary);
    display: inline-block;
    white-space: nowrap;
    transition: opacity var(--hover-transition-duration) var(--hover-transition-timing);
    flex-shrink: 0;
  }

  .jp-methods__cta-link:hover {
    opacity: var(--opacity-70);
  }

  @media (max-width: 768px) {
    .jp-methods__intro {
      grid-template-columns: 1fr;
      gap: var(--gap-xl);
    }
    .jp-guide__body {
      grid-template-columns: 1fr;
      padding-left: 0;
    }
    .jp-guide__trigger {
      grid-template-columns: 2rem 1fr 1.5rem;
      gap: var(--gap-lg);
    }
    .jp-methods__cta {
      flex-direction: column;
      align-items: flex-start;
      padding: var(--padding-2xl);
      margin-top: var(--padding-5xl);
    }
    .jp-methods {
      padding-top: calc({{ section.settings.padding_top }}px * var(--spacing-scale-sm, 0.6));
      padding-bottom: calc({{ section.settings.padding_bottom }}px * var(--spacing-scale-sm, 0.6));
    }
  }
</style>

<section class="jp-methods" id="jumbo-methods">
  <div class="jp-methods__inner">

    <header class="jp-methods__intro">
      <div>
        <p class="jp-methods__eyebrow">{{ section.settings.eyebrow | default: 'Printing Methods' }}</p>
        <h2 class="jp-methods__heading">{{ section.settings.heading | default: 'How we <em>print</em>' }}</h2>
      </div>
      <p class="jp-methods__intro-body">{{ section.settings.intro_text | default: "We've got two risographs, a giclée printer, and a real soft spot for anyone trying to make something worth printing. Based in Barcelona, we take on runs of all sizes." }}</p>
    </header>

    <div class="jp-methods__tabs" role="tablist">
      <button
        class="jp-methods__tab"
        role="tab"
        data-method="riso"
        aria-selected="true"
        aria-controls="panel-riso"
        id="tab-riso"
        onclick="jpSwitchTab('riso')"
      >
        Risograph
      </button>
      <button
        class="jp-methods__tab"
        role="tab"
        data-method="giclee"
        aria-selected="false"
        aria-controls="panel-giclee"
        id="tab-giclee"
        onclick="jpSwitchTab('giclee')"
      >
        Giclée
      </button>
    </div>

    {%- comment -%} ─────────────────── RISO PANEL ─────────────────── {%- endcomment -%}
    <div class="jp-methods__panel" id="panel-riso" role="tabpanel" aria-hidden="false" aria-labelledby="tab-riso">
      <span class="jp-badge jp-badge--riso">Risograph · Up to A3</span>

      {%- assign riso_blocks = section.blocks | where: 'type', 'riso_guide' -%}
      {%- for block in riso_blocks -%}
        <details class="jp-guide" {{ block.shopify_attributes }}>
          <summary class="jp-guide__trigger" onclick="return false;">
            <span class="jp-guide__num">0{{ forloop.index }}</span>
            <span class="jp-guide__title">{{ block.settings.title }}</span>
            <span class="jp-guide__arrow">+</span>
          </summary>
          <div class="jp-guide__body">
            <div>
              <div class="jp-guide__text">{{ block.settings.body }}</div>
              {% if block.settings.image != blank %}
                <img
                  class="jp-guide__image"
                  src="{{ block.settings.image | image_url: width: 1200 }}"
                  alt="{{ block.settings.title }}"
                  loading="lazy"
                  width="1200"
                >
              {% endif %}
            </div>
            {% if block.settings.spec_1_label != blank %}
              <div class="jp-guide__specs">
                {% for i in (1..6) %}
                  {%- assign label_key = 'spec_' | append: i | append: '_label' -%}
                  {%- assign value_key = 'spec_' | append: i | append: '_value' -%}
                  {%- assign spec_label = block.settings[label_key] -%}
                  {%- assign spec_value = block.settings[value_key] -%}
                  {% if spec_label != blank %}
                    <div class="jp-guide__spec-row">
                      <span class="jp-guide__spec-label">{{ spec_label }}</span>
                      <span class="jp-guide__spec-value">{{ spec_value }}</span>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </details>
      {%- endfor -%}
    </div>

    {%- comment -%} ─────────────────── GICLÉE PANEL ─────────────────── {%- endcomment -%}
    <div class="jp-methods__panel" id="panel-giclee" role="tabpanel" aria-hidden="true" aria-labelledby="tab-giclee">
      <span class="jp-badge jp-badge--giclee">Giclée · Up to A1</span>

      {%- assign giclee_blocks = section.blocks | where: 'type', 'giclee_guide' -%}
      {%- for block in giclee_blocks -%}
        <details class="jp-guide" {{ block.shopify_attributes }}>
          <summary class="jp-guide__trigger" onclick="return false;">
            <span class="jp-guide__num">0{{ forloop.index }}</span>
            <span class="jp-guide__title">{{ block.settings.title }}</span>
            <span class="jp-guide__arrow">+</span>
          </summary>
          <div class="jp-guide__body">
            <div>
              <div class="jp-guide__text">{{ block.settings.body }}</div>
              {% if block.settings.image != blank %}
                <img
                  class="jp-guide__image"
                  src="{{ block.settings.image | image_url: width: 1200 }}"
                  alt="{{ block.settings.title }}"
                  loading="lazy"
                  width="1200"
                >
              {% endif %}
            </div>
            {% if block.settings.spec_1_label != blank %}
              <div class="jp-guide__specs">
                {% for i in (1..6) %}
                  {%- assign label_key = 'spec_' | append: i | append: '_label' -%}
                  {%- assign value_key = 'spec_' | append: i | append: '_value' -%}
                  {%- assign spec_label = block.settings[label_key] -%}
                  {%- assign spec_value = block.settings[value_key] -%}
                  {% if spec_label != blank %}
                    <div class="jp-guide__spec-row">
                      <span class="jp-guide__spec-label">{{ spec_label }}</span>
                      <span class="jp-guide__spec-value">{{ spec_value }}</span>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </details>
      {%- endfor -%}
    </div>

    {% if section.settings.cta_text != blank %}
      <div class="jp-methods__cta">
        {% comment %} <span aria-hidden="true">校了</span> {% endcomment %}
        <p class="jp-methods__cta-text">{{ section.settings.cta_text }}</p>
        <a href="{{ section.settings.cta_url | default: 'mailto:hey@jumbo-press.com' }}" class="jp-methods__cta-link">
          {{ section.settings.cta_label | default: 'Get in touch' }} 
        </a>
      </div>
    {% endif %}

  </div>
</section>

<script>
  // Accordion toggle
  document.querySelectorAll('.jp-guide summary').forEach(function(summary) {
    summary.addEventListener('click', function(e) {
      e.preventDefault();
      var details = summary.closest('details');
      details.open = !details.open;
    });
  });

  // Tab switching
  function jpSwitchTab(method) {
    document.querySelectorAll('.jp-methods__tab').forEach(function(tab) {
      tab.setAttribute('aria-selected', tab.dataset.method === method ? 'true' : 'false');
    });
    document.querySelectorAll('.jp-methods__panel').forEach(function(panel) {
      panel.setAttribute('aria-hidden', panel.id === 'panel-' + method ? 'false' : 'true');
    });
  }
</script>

{% schema %}
{
  "name": "Print Methods",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Printing Methods" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "How we <em>print</em>" },
    { "type": "textarea", "id": "intro_text", "label": "Intro paragraph" },
    { "type": "text", "id": "cta_text", "label": "CTA italic text", "default": "Got a project in mind?" },
    { "type": "text", "id": "cta_label", "label": "CTA button label", "default": "Get in touch" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" },
    { "type": "range", "id": "padding_top", "min": 40, "max": 160, "step": 8, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 40, "max": 160, "step": 8, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "riso_guide",
      "name": "Riso Guide Section",
      "settings": [
        { "type": "text", "id": "title", "label": "Section title", "default": "Format & Margins" },
        { "type": "richtext", "id": "body", "label": "Body copy" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "spec_1_label", "label": "Spec 1 label" },
        { "type": "text", "id": "spec_1_value", "label": "Spec 1 value" },
        { "type": "text", "id": "spec_2_label", "label": "Spec 2 label" },
        { "type": "text", "id": "spec_2_value", "label": "Spec 2 value" },
        { "type": "text", "id": "spec_3_label", "label": "Spec 3 label" },
        { "type": "text", "id": "spec_3_value", "label": "Spec 3 value" },
        { "type": "text", "id": "spec_4_label", "label": "Spec 4 label" },
        { "type": "text", "id": "spec_4_value", "label": "Spec 4 value" },
        { "type": "text", "id": "spec_5_label", "label": "Spec 5 label" },
        { "type": "text", "id": "spec_5_value", "label": "Spec 5 value" }
      ]
    },
    {
      "type": "giclee_guide",
      "name": "Giclée Guide Section",
      "settings": [
        { "type": "text", "id": "title", "label": "Section title", "default": "About Giclée" },
        { "type": "richtext", "id": "body", "label": "Body copy" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "spec_1_label", "label": "Spec 1 label" },
        { "type": "text", "id": "spec_1_value", "label": "Spec 1 value" },
        { "type": "text", "id": "spec_2_label", "label": "Spec 2 label" },
        { "type": "text", "id": "spec_2_value", "label": "Spec 2 value" },
        { "type": "text", "id": "spec_3_label", "label": "Spec 3 label" },
        { "type": "text", "id": "spec_3_value", "label": "Spec 3 value" },
        { "type": "text", "id": "spec_4_label", "label": "Spec 4 label" },
        { "type": "text", "id": "spec_4_value", "label": "Spec 4 value" },
        { "type": "text", "id": "spec_5_label", "label": "Spec 5 label" },
        { "type": "text", "id": "spec_5_value", "label": "Spec 5 value" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Print Methods",
      "blocks": [
        {
          "type": "riso_guide",
          "settings": {
            "title": "Format & Margins",
            "body": "<p>Max sheet size is <strong>297 × 420 mm (A3)</strong> with a max image area of 287 × 410 mm. Keep at least 5 mm safe margins all around — 10 mm for dense ink areas. Avoid full-bleed right to the edge.</p>",
            "spec_1_label": "Max sheet",
            "spec_1_value": "A3 · 297 × 420mm",
            "spec_2_label": "Image area",
            "spec_2_value": "287 × 410mm",
            "spec_3_label": "Safe margin",
            "spec_3_value": "5mm min"
          }
        },
        {
          "type": "riso_guide",
          "settings": {
            "title": "Colour & Coverage",
            "body": "<p>Each pass is <strong>transparent</strong> — overlapping inks create new tones. Avoid dense fills at 100%; use 80–90% opacity for large colour areas. Flat colours may print unevenly — typical with big ink blocks.</p>",
            "spec_1_label": "Max coverage",
            "spec_1_value": "80–90%",
            "spec_2_label": "Overprints",
            "spec_2_value": "Avoid fine lines",
            "spec_3_label": "Layers",
            "spec_3_value": "Transparent / additive"
          }
        },
        {
          "type": "riso_guide",
          "settings": {
            "title": "Text & Lines",
            "body": "<p>Minimum font size is <strong>6 pt</strong>. Avoid very thin fonts or line weights under 0.25 pt. For small type, use solid black only — no layered inks.</p>",
            "spec_1_label": "Min font size",
            "spec_1_value": "6pt",
            "spec_2_label": "Min line weight",
            "spec_2_value": "0.25pt",
            "spec_3_label": "Small type",
            "spec_3_value": "Black only"
          }
        },
        {
          "type": "riso_guide",
          "settings": {
            "title": "Paper",
            "body": "<p>We print exclusively on <strong>uncoated paper</strong>, FSC-certified stock. Weight range 80g to 300g. We frequently work with Fedrigoni papers from Italy and locally sourced papers from Barcelona.</p>",
            "spec_1_label": "Weight range",
            "spec_1_value": "80g – 300g",
            "spec_2_label": "Finish",
            "spec_2_value": "Uncoated only",
            "spec_3_label": "Certification",
            "spec_3_value": "FSC-certified"
          }
        },
        {
          "type": "riso_guide",
          "settings": {
            "title": "File Setup",
            "body": "<p>Submit one <strong>flattened, greyscale PDF</strong> per colour layer. PSDs with colour layers accepted for A3. 300 dpi minimum. Include a colour reference preview (RGB or CMYK OK).</p>",
            "spec_1_label": "Format",
            "spec_1_value": "PDF per layer / PSD",
            "spec_2_label": "Resolution",
            "spec_2_value": "300 dpi",
            "spec_3_label": "Colour mode",
            "spec_3_value": "Greyscale per layer"
          }
        },
        {
          "type": "riso_guide",
          "settings": {
            "title": "Production Notes",
            "body": "<p>Minimum run is <strong>30 copies</strong>. Riso is a duplicator — each layer prints via stencil and drum. Expect slight shifts, texture, and roller marks. Oil-based inks are slow-drying, especially in multi-layer prints.</p>",
            "spec_1_label": "Min run",
            "spec_1_value": "30 copies",
            "spec_2_label": "Registration",
            "spec_2_value": "Slight shifts expected",
            "spec_3_label": "Ink type",
            "spec_3_value": "Oil-based"
          }
        },
        {
          "type": "giclee_guide",
          "settings": {
            "title": "About Giclée",
            "body": "<p>Giclée is a professional fine art process using <strong>archival pigment inks</strong> and museum-grade paper. Produces vibrant, long-lasting prints that faithfully reproduce your artwork. We print on <strong>Hahnemühle Photo Matt Fibre 200 gsm</strong>.</p>",
            "spec_1_label": "Ink type",
            "spec_1_value": "Archival pigment",
            "spec_2_label": "Paper",
            "spec_2_value": "Hahnemühle 200gsm",
            "spec_3_label": "Max size",
            "spec_3_value": "A1 · 59.4 × 84.1cm"
          }
        },
        {
          "type": "giclee_guide",
          "settings": {
            "title": "File Requirements",
            "body": "<p>Provide files at <strong>300 dpi at final print size</strong>. Colour profiles: Adobe RGB (1998) or ProPhoto RGB. TIFF or high-quality uncompressed JPEG. Include exact dimensions wanted and leave 5–10 mm around edges for trimming.</p>",
            "spec_1_label": "Resolution",
            "spec_1_value": "300 dpi",
            "spec_2_label": "Colour profile",
            "spec_2_value": "Adobe RGB / ProPhoto",
            "spec_3_label": "Format",
            "spec_3_value": "TIFF or JPEG"
          }
        },
